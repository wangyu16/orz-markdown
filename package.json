{
  "name": "orz-markdown",
  "version": "1.6.3",
  "description": "Markdown renderer and single-file, self-editing HTML document family with math, diagrams, themes, and source-aware copy.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime.js",
    "./preview-frame": "./dist/preview-frame.js",
    "./themes/*": "./themes/*",
    "./doc-meta": "./dist/doc-meta.js"
  },
  "files": [
    "dist",
    "themes",
    "orz-markdown-skills"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:starters": "tsx scripts/check-site-starters.ts",
    "check:site": "npm run check:starters && tsx scripts/check-site-discovery.ts",
    "visibility:baseline": "tsx scripts/visibility-baseline.ts",
    "render": "tsx scripts/render.ts",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "markdown",
    "markdown-it",
    "parser",
    "plugin",
    "katex",
    "mermaid",
    "smiles",
    "qrcode",
    "toc",
    "footnote"
  ],
  "author": "Yu Wang <yuwang@orz.how>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangyu16/orz-markdown.git"
  },
  "homepage": "https://markdown.orz.how/",
  "bugs": "https://github.com/wangyu16/orz-markdown/issues",
  "dependencies": {
    "@traptitech/markdown-it-katex": "^3.6.0",
    "katex": "^0.16.35",
    "markdown-it": "^14.3.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "node-emoji": "^2.2.0",
    "qrcode-svg": "^1.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-anchor": "^7.0.0",
    "@types/markdown-it-container": "^4.0.0",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/node": "^25.3.5",
    "@types/qrcode-svg": "^1.1.5",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "path-browserify": "^1.0.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
